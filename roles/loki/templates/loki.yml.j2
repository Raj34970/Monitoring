auth_enabled: false

server:
  http_listen_port: 3100

common:
  path_prefix: {{ loki_data_path }}/loki
  storage:
    filesystem:
      chunks_directory: {{ loki_data_path }}/loki/chunks
      rules_directory: {{ loki_data_path }}/loki/rules
  replication_factor: 1
  ring:
    kvstore:
      store: inmemory

schema_config:
  configs:
    - from: 2026-02-11
      store: tsdb
      object_store: filesystem
      schema: v13
      index:
        prefix: index_
        period: 24h

limits_config:
  retention_period: 168h

compactor:
  working_directory: {{ loki_data_path }}/loki/compactor
  shared_store: filesystem
