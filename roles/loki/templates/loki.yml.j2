auth_enabled: false

server:
  http_listen_port: {{ loki_port }}

ingester:
  wal:
    enabled: true
  chunk_idle_period: 5m

storage_config:
  boltdb:
    directory: {{ loki_data_path }}

schema_config:
  configs:
    - from: 2020-10-24
      store: boltdb
      object_store: filesystem
      schema: v11
      index:
        prefix: index_
        period: 24h
